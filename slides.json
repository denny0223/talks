---
layout: null
permalink: /slides.json
sitemap: false
---
[
{% assign slides = site.slides | sort: "title" %}
{% for slide in slides %}
  {% assign related_events = site.events | where_exp: "event", "event.slides contains slide.slug" | sort: "date" | reverse %}
  {% assign related_date_groups = related_events | group_by_exp: "event", "event.date | date: '%Y-%m-%d'" %}
  {
    "id": {{ slide.slug | jsonify }},
    "title": {{ slide.title | jsonify }},
    "external_url": {{ slide.external_url | jsonify }},
    "summary": {{ slide.summary | jsonify }},
    "topics": {{ slide.topics | jsonify }},
    "language": {{ slide.language | jsonify }},
    "first_presented": {{ slide.first_presented | jsonify }},
    "aliases": {{ slide.aliases | jsonify }},
    "related_events": [{% assign related_emitted = 0 %}{% for date_group in related_date_groups %}{% assign date_events = date_group.items | sort: "sequence" %}{% for event in date_events %}{% unless related_emitted == 0 %}, {% endunless %}{{ event.slug | jsonify }}{% assign related_emitted = related_emitted | plus: 1 %}{% endfor %}{% endfor %}],
    "url": {{ slide.url | absolute_url | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
