#!/usr/bin/env node

const fs = require("node:fs");
const path = require("node:path");

const root = path.resolve(__dirname, "..");
if (process.argv.includes("--help") || process.argv.includes("-h")) {
  usage();
}

const args = new Map();
for (let i = 2; i < process.argv.length; i += 2) {
  const key = process.argv[i];
  const value = process.argv[i + 1];
  if (!key || !key.startsWith("--") || value === undefined) {
    usage();
  }
  args.set(key.slice(2), value);
}

for (const required of ["date", "title", "event"]) {
  if (!args.has(required)) usage(`Missing --${required}`);
}

const date = args.get("date");
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) usage("--date must use YYYY-MM-DD");
const endDate = args.get("end-date") || "";
if (endDate && !/^\d{4}-\d{2}-\d{2}$/.test(endDate)) usage("--end-date must use YYYY-MM-DD");
if (endDate && endDate < date) usage("--end-date must not be earlier than --date");
const explicitSequence = args.get("sequence") ? Number(args.get("sequence")) : null;
if (args.get("sequence") && (!Number.isInteger(explicitSequence) || explicitSequence < 1)) usage("--sequence must be a positive integer");

function usage(message) {
  if (message) console.error(message);
  console.error(`Usage:
  scripts/new-event --date YYYY-MM-DD --title "Talk title" --event "Event name" [--event-url URL] [--slide slide-id] [--topics topic-a,topic-b] [--end-date YYYY-MM-DD]

Advanced:
  --sequence N   Only for appending the next record to a date that already has events. Omit it for normal use.`);
  process.exit(1);
}

function slugify(input) {
  return input
    .normalize("NFKD")
    .replace(/[^\w\s-]/g, " ")
    .toLowerCase()
    .replace(/_/g, "-")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "")
    .slice(0, 70)
    .replace(/-$/g, "") || "event";
}

function yamlString(value) {
  return JSON.stringify(value || "");
}

function yamlArray(values) {
  if (!values || values.length === 0) return "[]";
  return `\n${values.map((value) => `  - ${yamlString(value)}`).join("\n")}`;
}

function parseFrontMatter(source) {
  const data = {};
  const match = source.match(/^---\n([\s\S]*?)\n---\n?/);
  if (!match) return data;
  for (const line of match[1].split(/\n/)) {
    const top = line.match(/^([A-Za-z0-9_-]+):(?:\s*(.*))?$/);
    if (!top) continue;
    const raw = top[2] || "";
    if (raw.startsWith('"')) data[top[1]] = JSON.parse(raw);
    else if (/^-?\d+$/.test(raw)) data[top[1]] = Number(raw);
    else data[top[1]] = raw;
  }
  return data;
}

function readEvent(file) {
  const fullPath = path.join(root, "_events", file);
  return {
    file,
    fullPath,
    data: parseFrontMatter(fs.readFileSync(fullPath, "utf8")),
  };
}

function sameDateSummary(events) {
  return events
    .map((event) => `${event.file}${Number.isInteger(event.data.sequence) ? ` sequence=${event.data.sequence}` : " sequence=<missing>"}`)
    .join("\n  ");
}

function writeSequence(event, sequence) {
  const text = fs.readFileSync(event.fullPath, "utf8");
  const match = text.match(/^---\n([\s\S]*?)\n---\n?/);
  if (!match) {
    console.error(`${event.file}: missing front matter`);
    process.exit(1);
  }

  const lines = match[1].split("\n");
  const sequenceIndex = lines.findIndex((line) => line.startsWith("sequence:"));
  if (sequenceIndex >= 0) {
    lines[sequenceIndex] = `sequence: ${sequence}`;
  } else {
    const endDateIndex = lines.findIndex((line) => line.startsWith("end_date:"));
    const dateIndex = lines.findIndex((line) => line.startsWith("date:"));
    lines.splice((endDateIndex >= 0 ? endDateIndex : dateIndex) + 1, 0, `sequence: ${sequence}`);
  }

  fs.writeFileSync(event.fullPath, `---\n${lines.join("\n")}\n---\n\n${text.slice(match[0].length)}`);
  event.data.sequence = sequence;
}

const slug = `${date}-${slugify(args.get("title"))}`;
const filePath = path.join(root, "_events", `${slug}.md`);
if (fs.existsSync(filePath)) {
  console.error(`${filePath} already exists`);
  process.exit(1);
}

const topics = args.get("topics") ? args.get("topics").split(",").map((item) => item.trim()).filter(Boolean) : [];
const slides = args.get("slide") ? args.get("slide").split(",").map((item) => item.trim()).filter(Boolean) : [];
const sameDateEvents = fs.readdirSync(path.join(root, "_events"))
  .filter((file) => file.endsWith(".md"))
  .map(readEvent)
  .filter((event) => event.data.date === date)
  .sort((a, b) => a.file.localeCompare(b.file));
const updatedEvents = [];

if (sameDateEvents.length === 0 && explicitSequence) {
  console.error("--sequence is only allowed when another event already uses the same date");
  process.exit(1);
}

if (sameDateEvents.length > 0) {
  const expectedSequence = sameDateEvents.length + 1;
  if (explicitSequence && explicitSequence !== expectedSequence) {
    console.error(`--sequence must append as ${expectedSequence} for ${date}. Existing events:\n  ${sameDateSummary(sameDateEvents)}`);
    process.exit(1);
  }

  if (sameDateEvents.length === 1 && !Number.isInteger(sameDateEvents[0].data.sequence)) {
    writeSequence(sameDateEvents[0], 1);
    updatedEvents.push(sameDateEvents[0]);
  }

  const invalidSequenceEvents = sameDateEvents.filter((event) => !Number.isInteger(event.data.sequence));
  if (invalidSequenceEvents.length > 0) {
    console.error(`Existing same-day events must have sequence before adding another ${date} event:\n  ${sameDateSummary(sameDateEvents)}`);
    process.exit(1);
  }

  const expectedExisting = new Set(Array.from({ length: sameDateEvents.length }, (_, index) => index + 1));
  for (const event of sameDateEvents) {
    expectedExisting.delete(event.data.sequence);
  }
  if (expectedExisting.size > 0) {
    console.error(`Existing same-day sequences for ${date} must be continuous before adding another event:\n  ${sameDateSummary(sameDateEvents)}`);
    process.exit(1);
  }
}

const sequence = sameDateEvents.length > 0 ? (explicitSequence || sameDateEvents.length + 1) : null;
if (sequence && sameDateEvents.some((event) => event.data.sequence === sequence)) {
  console.error(`Another event on ${date} already uses sequence ${sequence}. Existing events:\n  ${sameDateSummary(sameDateEvents)}`);
  process.exit(1);
}
const slideDir = path.join(root, "_slides");
for (const slide of slides) {
  if (!fs.existsSync(path.join(slideDir, `${slide}.md`))) {
    console.error(`Unknown slide '${slide}'. Create _slides/${slide}.md first or use an existing slide id.`);
    process.exit(1);
  }
}

const body = `---
title: ${yamlString(args.get("title"))}
date: ${date}
${endDate ? `end_date: ${endDate}\n` : ""}${sequence ? `sequence: ${sequence}\n` : ""}event: ${yamlString(args.get("event"))}
event_url: ${yamlString(args.get("event-url") || "")}
role: "speaker"
language: "zh-TW"
summary: ""
topics: ${yamlArray(topics)}
slides: ${yamlArray(slides)}
videos: []
links: []
---

${args.get("event")} : ${args.get("title")}
`;

fs.writeFileSync(filePath, body);
console.log(`Created ${path.relative(root, filePath)}`);
for (const event of updatedEvents) {
  console.log(`Updated ${path.relative(root, event.fullPath)}`);
}
