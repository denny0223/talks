#!/usr/bin/env node

const fs = require("node:fs");
const path = require("node:path");

const root = path.resolve(__dirname, "..");
const collections = {
  events: path.join(root, "_events"),
  slides: path.join(root, "_slides"),
  topics: path.join(root, "_topics"),
};

function fail(message) {
  console.error(message);
  process.exitCode = 1;
}

function readCollection(dir) {
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter((file) => file.endsWith(".md"))
    .sort()
    .map((file) => {
      const fullPath = path.join(dir, file);
      const text = fs.readFileSync(fullPath, "utf8");
      const match = text.match(/^---\n([\s\S]*?)\n---\n?/);
      if (!match) {
        fail(`${file}: missing front matter`);
        return { file, data: {}, body: text };
      }
      return { file, slug: file.replace(/\.md$/, ""), data: parseFrontMatter(match[1]), body: text.slice(match[0].length) };
    });
}

function parseFrontMatter(source) {
  const data = {};
  const lines = source.split(/\n/);
  let key = null;
  for (const line of lines) {
    const top = line.match(/^([A-Za-z0-9_-]+):(?:\s*(.*))?$/);
    if (top) {
      key = top[1];
      const raw = top[2] || "";
      if (raw === "[]") data[key] = [];
      else data[key] = parseScalar(raw);
      continue;
    }
    const list = line.match(/^\s+-\s+(.*)$/);
    if (list && key) {
      if (!Array.isArray(data[key])) data[key] = [];
      const raw = list[1];
      if (!raw.startsWith('"') && raw.includes(": ")) {
        const [firstKey, ...rest] = raw.split(": ");
        const item = { [firstKey]: JSON.parse(rest.join(": ")) };
        data[key].push(item);
      } else {
        data[key].push(parseScalar(raw));
      }
      continue;
    }
    const nested = line.match(/^\s+([A-Za-z0-9_-]+):\s+(.*)$/);
    if (nested && key && Array.isArray(data[key]) && data[key].length > 0) {
      data[key][data[key].length - 1][nested[1]] = parseScalar(nested[2]);
    }
  }
  return data;
}

function parseScalar(raw) {
  if (raw === "") return "";
  if (raw === "true") return true;
  if (raw === "false") return false;
  if (/^-?\d+$/.test(raw)) return Number(raw);
  if (raw.startsWith('"')) return JSON.parse(raw);
  return raw;
}

function validUrl(url) {
  if (!url) return true;
  try {
    const parsed = new URL(url);
    return parsed.protocol === "https:" || parsed.protocol === "http:" || parsed.protocol === "mailto:";
  } catch {
    return false;
  }
}

function validDate(value) {
  return typeof value === "string" && /^\d{4}-\d{2}-\d{2}$/.test(value);
}

function hasGenericSlideDescription(value) {
  return /相關投影片|投影片，涵蓋|最早使用於/.test(value || "");
}

const events = readCollection(collections.events);
const slides = readCollection(collections.slides);
const topics = readCollection(collections.topics);
const slideIds = new Set(slides.map((slide) => slide.slug));
const topicIds = new Set(topics.map((topic) => topic.slug));
const slideUrls = new Map(slides.map((slide) => [slide.slug, slide.data.external_url]));
const validRoles = new Set(["speaker", "panelist", "judge", "host", "interviewee"]);
const validLanguages = new Set(["zh-TW", "en"]);

for (const [name, records] of Object.entries({ events, slides, topics })) {
  const seen = new Set();
  for (const record of records) {
    if (seen.has(record.slug)) fail(`${name}/${record.file}: duplicate slug`);
    seen.add(record.slug);
  }
}

const eventsByDate = new Map();

function sameDateSummary(events) {
  return events
    .map((event) => `${event.file}${Number.isInteger(event.data.sequence) ? ` sequence=${event.data.sequence}` : " sequence=<missing>"}`)
    .join(", ");
}

for (const event of events) {
  for (const field of ["title", "date", "summary", "topics"]) {
    if (!event.data[field] || (Array.isArray(event.data[field]) && event.data[field].length === 0)) {
      fail(`_events/${event.file}: missing ${field}`);
    }
  }
  if ("display_date" in event.data) fail(`_events/${event.file}: display_date is generated from date and end_date`);
  if ("date_label" in event.data) fail(`_events/${event.file}: date_label is not supported; encode the date range with date and end_date`);
  if (!validDate(event.data.date)) fail(`_events/${event.file}: invalid date; must use YYYY-MM-DD`);
  if (!validRoles.has(event.data.role)) fail(`_events/${event.file}: invalid role ${event.data.role}`);
  if (!validLanguages.has(event.data.language)) fail(`_events/${event.file}: invalid language ${event.data.language}`);
  if (event.data.end_date) {
    if (!validDate(event.data.end_date)) fail(`_events/${event.file}: invalid end_date; must use YYYY-MM-DD`);
    else if (event.data.end_date < event.data.date) fail(`_events/${event.file}: end_date must not be earlier than date`);
  }
  if (event.data.sequence !== undefined && (!Number.isInteger(event.data.sequence) || event.data.sequence < 1)) {
    fail(`_events/${event.file}: sequence must be a positive integer`);
  }
  if (!eventsByDate.has(event.data.date)) eventsByDate.set(event.data.date, []);
  eventsByDate.get(event.data.date).push(event);
  if (!validUrl(event.data.event_url)) fail(`_events/${event.file}: invalid event_url`);
  if (event.data.event_url && !event.data.event) fail(`_events/${event.file}: event_url requires event text for links and metadata`);
  for (const topic of event.data.topics || []) {
    if (!topicIds.has(topic)) fail(`_events/${event.file}: unknown topic ${topic}`);
  }
  for (const slide of event.data.slides || []) {
    if (!slideIds.has(slide)) fail(`_events/${event.file}: unknown slide ${slide}`);
  }
  const referencedSlideUrls = (event.data.slides || []).map((slide) => slideUrls.get(slide)).filter(Boolean);
  const referencedVideoUrls = (event.data.videos || []).map((video) => video.url).filter(Boolean);
  if (event.data.event_url && referencedSlideUrls.includes(event.data.event_url)) {
    fail(`_events/${event.file}: event_url points to a referenced slide URL`);
  }
  if (event.data.event_url && referencedVideoUrls.includes(event.data.event_url)) {
    fail(`_events/${event.file}: event_url points to a referenced video URL`);
  }
  for (const group of ["videos", "links"]) {
    for (const link of event.data[group] || []) {
      if (!validUrl(link.url)) fail(`_events/${event.file}: invalid ${group} URL ${link.url}`);
    }
  }
}

for (const [date, dateEvents] of eventsByDate) {
  if (dateEvents.length === 1) {
    if (dateEvents[0].data.sequence !== undefined) {
      fail(`_events/${dateEvents[0].file}: sequence is only allowed when multiple events share ${date}`);
    }
    continue;
  }

  const seenSequences = new Set();
  const summary = sameDateSummary(dateEvents);
  for (const event of dateEvents) {
    const sequence = event.data.sequence;
    if (!Number.isInteger(sequence)) {
      fail(`_events/${event.file}: missing sequence for same-day events on ${date}; same-day files: ${summary}`);
      continue;
    }
    if (seenSequences.has(sequence)) fail(`_events/${event.file}: duplicate sequence ${sequence} on ${date}; same-day files: ${summary}`);
    seenSequences.add(sequence);
  }
  for (let sequence = 1; sequence <= dateEvents.length; sequence += 1) {
    if (!seenSequences.has(sequence)) fail(`${date}: same-day sequences must be continuous from 1 to ${dateEvents.length}; same-day files: ${summary}`);
  }
}

const featuredOrders = new Map();
for (const slide of slides) {
  for (const field of ["title", "external_url", "summary", "topics", "first_presented"]) {
    if (!slide.data[field] || (Array.isArray(slide.data[field]) && slide.data[field].length === 0)) {
      fail(`_slides/${slide.file}: missing ${field}`);
    }
  }
  if (hasGenericSlideDescription(slide.data.summary)) {
    fail(`_slides/${slide.file}: summary must describe the deck's reader value, not say it is a related slide or repeat metadata`);
  }
  if (hasGenericSlideDescription(slide.body)) {
    fail(`_slides/${slide.file}: body must not use generic related-slide wording`);
  }
  if (!validUrl(slide.data.external_url)) fail(`_slides/${slide.file}: invalid external_url`);
  if (!validLanguages.has(slide.data.language)) fail(`_slides/${slide.file}: invalid language ${slide.data.language}`);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(slide.data.first_presented)) fail(`_slides/${slide.file}: invalid first_presented; must use YYYY-MM-DD`);
  for (const topic of slide.data.topics || []) {
    if (!topicIds.has(topic)) fail(`_slides/${slide.file}: unknown topic ${topic}`);
  }
  if (slide.data.featured === true) {
    if (!Number.isInteger(slide.data.featured_order)) {
      fail(`_slides/${slide.file}: featured slide must set numeric featured_order`);
    } else if (featuredOrders.has(slide.data.featured_order)) {
      fail(`_slides/${slide.file}: duplicate featured_order ${slide.data.featured_order} also used by ${featuredOrders.get(slide.data.featured_order)}`);
    } else {
      featuredOrders.set(slide.data.featured_order, slide.file);
    }
  }
}

for (const topic of topics) {
  for (const field of ["title", "summary"]) {
    if (!topic.data[field]) fail(`_topics/${topic.file}: missing ${field}`);
  }
}

if (!process.exitCode) {
  console.log(`Validated ${events.length} events, ${slides.length} slides, ${topics.length} topics.`);
}
